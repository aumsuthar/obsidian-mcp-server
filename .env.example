# Absolute path to your Obsidian vault on this device
OBSIDIAN_VAULT_PATH=""        # e.g. /Users/you/Documents/Obsidian Vault

# Daily notes folder and date format (optional — defaults shown)
# OBSIDIAN_DAILY_DIR="Daily"
# OBSIDIAN_DAILY_FORMAT="YYYY-MM-DD"

# Templates folder (optional — default shown)
# OBSIDIAN_TEMPLATES_DIR="Templates"

# Auto-sync intervals in minutes (optional — disabled by default)
# OBSIDIAN_AUTO_PUSH_MINUTES=5     # auto-commit and push every 5 minutes
# OBSIDIAN_AUTO_PULL_MINUTES=5     # auto-pull from git every 5 minutes
